{
  "expo": {
    "name": "Cancionero",
    "slug": "cancionero",
    "version": "1.2.0",
    "orientation": "portrait",
    "scheme": "cancionero",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mateolorenzo.cancionero",
      "icon": "./assets/images/ios-icon.png",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#000000",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "supportsTablet": false,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mateolorenzo.cancionero2",
      "versionCode": 8
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/ios-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          },
          "android": {
            "image": "./assets/images/android-splash-icon.png",
            "imageWidth": 320,
            "resizeMode": "contain",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8591b348-9eac-4ccf-bfeb-1d7bce5c0f4d"
      }
    },
    "owner": "mateolorenzo",
    "updates": {
      "url": "https://u.expo.dev/8591b348-9eac-4ccf-bfeb-1d7bce5c0f4d",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    }
  }
}